FROM python:3.13-slim
WORKDIR /app
COPY admin_api/requirements.txt ./admin_api_requirements.txt
COPY pipeline/requirements.txt ./pipeline_requirements.txt
RUN pip install --no-cache-dir -r admin_api_requirements.txt -r pipeline_requirements.txt
COPY admin_api/ ./admin_api/
COPY pipeline/ ./pipeline/
EXPOSE 8300
CMD ["uvicorn", "admin_api.main:app", "--host", "0.0.0.0", "--port", "8300"]
