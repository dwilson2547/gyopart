    },
    {
      "id": "n_veh",
      "type": "text",
      "text": "## Vehicle\n**id**, source, source_key *(UNIQUE dedup)*\nvin *(nullable, 17 chars, indexed)*\nyear, make, model, trim\nextras *(JSONB — yard-specific fields)*\ncar_id, car_id_resolved\ncar_id_method, car_id_confidence\nlocation_id → Location",
